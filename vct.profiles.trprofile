    {
      "name": "Amizade",
      "customHotkey": "Ctrl\u002BNum4",
      "customHotstring": null,
      "targetWindow": null,
      "batchDelay": "Delay (ms)",
      "actions": [
        {
          "actionType": "SendText",
          "key": "\uD83D\uDE4B\u200D\u2642\uFE0FOl\u00E1, siga as instru\u00E7\u00F5es para receber o seu pedido:\n\n1. ACEITE pedido de amizade\n\n2. Nome = {clipboard}\n\n3. Voc\u00EA entra no jogo\n\n4. Fique online e AGUARDE. Eu vou at\u00E9 voc\u00EA!\n{enter}",
