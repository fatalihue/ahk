    {
      "name": "Andamento",
      "customHotkey": "Ctrl\u002BNum1",
      "customHotstring": null,
      "targetWindow": null,
      "batchDelay": "Delay (ms)",
      "actions": [
        {
          "actionType": "SendText",
          "key": "\uD83D\uDE4B\u200D\u2642\uFE0FOl\u00E1, seja bem vindo!\n\nSeu pedido est\u00E1 na fila e ser\u00E1 entregue nos pr\u00F3ximos minutos\nNossa equipe j\u00E1 est\u00E1 cuidando de tudo!\n\n\uD83D\uDE0E\u200B Por favor AGUARDE A SUA VEZ !!! \u200B\uD83D\uDE03\n{enter}",
