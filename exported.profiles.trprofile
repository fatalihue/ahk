    {
      "name": "Hora",
      "customHotkey": "F9",
      "customHotstring": null,
      "targetWindow": null,
      "batchDelay": "Delay (ms)",
      "actions": [
        {
          "actionType": "SendText",
          "key": "\uD83D\uDE4B\u200D\u2642\uFE0F\uD83D\uDE0E Ol\u00E1!\n\nNosso hor\u00E1rio de atendimento \u00E9:\n\nSegunda a Sexta: 09:00 \u00E0s 00:00\nFinais de semana: 09:00 \u00E0s 00:00\nFeriados: 09:00 \u00E0s 00:00\n\nVoc\u00EA logo ser\u00E1 atendido por um de nossos atendentes caso esteja dentro do hor\u00E1rio de atendimento.\n\nAo ser atendido, por gentileza, permane\u00E7a online no chat.\n{enter}",
          "x": 0,
          "y": 0,
          "delay": 20,
          "comment": null,
          "isInsertionPoint": false,
          "isVisuallyDeselected": false,
          "shouldHighlight": false,
          "displayX": "",
          "displayY": "",
          "displayKey": "\uD83D\uDE4B\u200D\u2642\uFE0F\uD83D\uDE0E Ol\u00E1!\n\nNosso hor\u00E1rio de atendimento \u00E9:\n\nSegunda a Sexta: 09:00 \u00E0s 00:00\nFinais de semana: 09:00 \u00E0s 00:00\nFeriados: 09:00 \u00E0s 00:00\n\nVoc\u00EA logo ser\u00E1 atendido por um de nossos atendentes caso esteja dentro do hor\u00E1rio de atendimento.\n\nAo ser atendido, por gentileza, permane\u00E7a online no chat.\n{enter}"
