    {
      "name": "Informe",
      "customHotkey": "Ctrl\u002BNum3",
      "customHotstring": null,
      "targetWindow": null,
      "batchDelay": "Delay (ms)",
      "actions": [
        {
          "actionType": "SendText",
          "key": "\uD83D\uDE4B\u200D\u2642\uFE0FOl\u00E1, vou localizar seu pedido!\nPra conseguir te ajudar Por favor me informe algum desses dados:\n\n1) E-MAIL cadastrado em nosso site.\n2) Nome completo do pagador.\n3) N\u00FAmero do pedido (ID da compra);\n4) Comprovante de Pagamento PIX.\n{enter}",
          "x": 0,
          "y": 0,
          "delay": 20,
          "comment": null,
          "isInsertionPoint": false,
          "isVisuallyDeselected": false,
          "shouldHighlight": false,
          "displayX": "",
          "displayY": "",
          "displayKey": "\uD83D\uDE4B\u200D\u2642\uFE0FOl\u00E1, vou localizar seu pedido!\nPra conseguir te ajudar Por favor me informe algum desses dados:\n\n1) E-MAIL cadastrado em nosso site.\n2) Nome completo do pagador.\n3) N\u00FAmero do pedido (ID da compra);\n4) Comprovante de Pagamento PIX.\n{enter}"
        },
